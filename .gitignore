# Downloaded standard PDFs — heavy binaries (~200 MB), not tracked.
# Provenance, SHA-256, size and page count for each are recorded in
# road-geometric-standards/MANIFEST.md, so the corpus is reproducible.
*.pdf

# Manual-download staging area (raw HTML saves + _files, etc. — not part of the tracked corpus)
road-geometric-standards/manual-download/

# On-the-fly text-extraction cache (regenerated by skill/scripts/search.py)
skill/.textcache/

# Phase 1 preprocessing artifacts — extracted FULL TEXT of standards (incl. copyrighted) + FTS index; NOT redistributed
corpus/
*.sqlite

# Python cruft
__pycache__/
*.pyc

# OS / Google Drive / editor cruft
desktop.ini
Thumbs.db
.DS_Store

# Phase-5 benchmark: raw page extracts used for answer-generation (copyrighted; regenerable)
eval/answer_tasks/
